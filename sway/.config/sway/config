# Default config for sway
#
# Read `man 5 sway` for a complete reference.

### Loading sub-configs
include ~/.config/sway/conf.d/theme/theme.conf
include ~/.config/sway/conf.d/autostart/autostart.conf
include ~/.config/sway/conf.d/input/input.conf
include ~/.config/sway/conf.d/keybinds/keybinds.conf
include ~/.config/sway/conf.d/app_rules/app_rules.conf

### Variables
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
set $term ghostty
# Your preferred application launcher
set $menu wmenu-run

### Output configuration
# Wallpaper géré par swww (voir conf.d/autostart : swww-daemon + wallpaper-restore.sh).
# Sélecteur par output : $mod+Shift+w → scripts/wallpaper-picker.sh
# (Ancien fond swaybg retiré pour ne pas doubler swww sur le layer background.)

# Example configuration:
#   output HDMI-A-1 resolution 1920x1080 position 1920,0
#   swaymsg -t get_outputs for output list

### Idle configuration (exemples)
# exec swayidle -w \
#     timeout 300 'swaylock -f -c 000000' \
#     timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
#     before-sleep 'swaylock -f -c 000000'

### Input configuration handled in conf.d/input.conf

### Keybindings handled in conf.d/keybinds.conf

### App rules handled in conf.d/app_rules.conf

### Status bar handled in conf.d/bar.conf

### Include system defaults

# For handling dialog boxes properly
exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP